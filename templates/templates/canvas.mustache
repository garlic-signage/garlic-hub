								<path d="M3232.5-1449v-191.6h191.6h191.6v191.6v191.6h-191.6h-191.6V-1449z" />
								<path d="M4018-1449v-191.6h191.6h191.6v191.6v191.6h-191.6H4018V-1449z" />
								<path d="M4803.6-1449v-191.6h191.6h191.6v191.6v191.6h-191.6h-191.6V-1449z" />
								<path d="M5589.2-1449v-191.6h191.6h191.6v191.6v191.6h-191.6h-191.6V-1449z" />
							</g>
						</g>
					</svg>
				</button>
				<div class="template_edit_dropdown_content" style="width:240px; padding:20px">
					<label for="strokeWidth">
						{{{LANG_OUTLINE_STRENGTH}}}
					</label>
					<div style="display: flex; justify-content:space-between; align-items: center;">
						<input id="strokeWidth" style="width:150px;" type="range" min="0" max="50" value="0">
						<span id="strokeWidthDisplay">0</span> px
					</div>
				</div>
			</div>
			</li>
            <li class="action-group" data-label="{{{LANG_SCALING}}}">
                <input type="number" id="scaleX" class="scaler" style="width:70px" min="0.1" max="10" step="0.1" title="{{{LANG_SCALE_X}}}" />
                <input type="number" id="scaleY" class="scaler" style="width:70px" min="0.1" max="10" step="0.1" title="{{{LANG_SCALE_Y}}}" />
            </li>
            <li>
                <input type="color" id="fillColor" class="color_button" style="display: none;" title="{{{LANG_SELECT_COLOR}}}" />
            </li>
            <li>
                <ul id="textProperties" class="action-group" style="display:none;" data-label="{{{LANG_TYPOGRAPHY}}}">
                    <li class="template_edit_dropdown">
                        <button id="fontFamily" style="font-size:0.7rem; width:150px; overflow: hidden;">
                            {{{LANG_FONT_FAMILY}}}
                        </button>
                        <div id="fontsDropdown" class="template_edit_dropdown_content" style="width:200px; height: 350px; overflow-y:auto;">
                            <!--                <div style="display:flex; justify-content:center; align-items:center; gap:10px;">
                        {{{LANG_UPLOAD_FONT}}}
                        <label class="template_edit_dropdown_file_input">
                            <input type="file" id="upload_font" style="display: none;" />
                            <svg xmlns="http://www.w3.org/2000/svg" width="17px" height="17px" viewBox="0 0 512 512">
                                <path
                                    d="M296 384h-80c-13.3 0-24-10.7-24-24V192h-87.7c-17.8 0-26.7-21.5-14.1-34.1L242.3 5.7c7.5-7.5 19.8-7.5 27.3 0l152.2 152.2c12.6 12.6 3.7 34.1-14.1 34.1H320v168c0 13.3-10.7 24-24 24zm216-8v112c0 13.3-10.7 24-24 24H24c-13.3 0-24-10.7-24-24V376c0-13.3 10.7-24 24-24h136v8c0 30.9 25.1 56 56 56h80c30.9 0 56-25.1 56-56v-8h136c13.3 0 24 10.7 24 24zm-124 88c0-11-9-20-20-20s-20 9-20 20 9 20 20 20 20-9 20-20zm64 0c0-11-9-20-20-20s-20 9-20 20 9 20 20 20 20-9 20-20z" />
                            </svg>
                        </label>
                    </div>
    -->
                        </div>
                    </li>
                    <li>
                        <button id="textAlign" class="svg_button" title="{{{LANG_ALIGN_TEXT}}}">
                            <i id="left" class="bi bi-justify-left"></i>
                            <i id="center" class="bi bi-justify"></i>
                            <i id="right" class="bi bi-justify-right"></i>
                        </button>
                    </li>
                    <li>
                        <button id="textBold" name="bold" class="bi bi-type-bold" title="{{{LANG_BOLD}}}"></button>
                    </li>
                    <li>
                        <button id="textItalic" name="italic" class="bi bi-type-italic" title="{{{LANG_ITALIC}}}"></button>
                    </li>
                    <li>
                        <button id="textUnderline" name="underline" class="bi bi-type-underline" title="{{{LANG_UNDERLINE}}}"></button>
                    </li>
                    <li>
                        <input style="width: 64px" type="number" id="fontSize" min="1" title="{{{LANG_FONT_SIZE}}}"/>
                    </li>
                </ul>
            </li>
        </ul>
	</li>
	<li>
		<ul id="group_properties" class="action-group">
			<li>
				<button id="object_group" style="display: none;" title="{{{LANG_GROUP_UNGROUP}}}">
					<svg id="group" xmlns="http://www.w3.org/2000/svg" width="17px" height="17px" viewBox="0 0 512 512">
						<path fill="currentColor" d="M480 128V96h20c6.627 0 12-5.373 12-12V44c0-6.627-5.373-12-12-12h-40c-6.627 0-12 5.373-12 12v20H64V44c0-6.627-5.373-12-12-12H12C5.373 32 0 37.373 0 44v40c0 6.627 5.373 12 12 12h20v320H12c-6.627 0-12 5.373-12 12v40c0 6.627 5.373 12 12 12h40c6.627 0 12-5.373 12-12v-20h384v20c0 6.627 5.373 12 12 12h40c6.627 0 12-5.373 12-12v-40c0-6.627-5.373-12-12-12h-20V128zM96 276V140c0-6.627 5.373-12 12-12h168c6.627 0 12 5.373 12 12v136c0 6.627-5.373 12-12 12H108c-6.627 0-12-5.373-12-12zm320 96c0 6.627-5.373 12-12 12H236c-6.627 0-12-5.373-12-12v-52h72c13.255 0 24-10.745 24-24v-72h84c6.627 0 12 5.373 12 12v136z" />
					</svg>
					<svg id="ungroup" xmlns="http://www.w3.org/2000/svg" width="17px" height="17px" viewBox="0 0 576 512">
						<path fill="currentColor" d="M64 320v26a6 6 0 0 1-6 6H6a6 6 0 0 1-6-6v-52a6 6 0 0 1 6-6h26V96H6a6 6 0 0 1-6-6V38a6 6 0 0 1 6-6h52a6 6 0 0 1 6 6v26h288V38a6 6 0 0 1 6-6h52a6 6 0 0 1 6 6v52a6 6 0 0 1-6 6h-26v192h26a6 6 0 0 1 6 6v52a6 6 0 0 1-6 6h-52a6 6 0 0 1-6-6v-26H64zm480-64v-32h26a6 6 0 0 0 6-6v-52a6 6 0 0 0-6-6h-52a6 6 0 0 0-6 6v26H408v72h8c13.255 0 24 10.745 24 24v64c0 13.255-10.745 24-24 24h-64c-13.255 0-24-10.745-24-24v-8H192v72h-26a6 6 0 0 0-6 6v52a6 6 0 0 0 6 6h52a6 6 0 0 0 6-6v-26h288v26a6 6 0 0 0 6 6h52a6 6 0 0 0 6-6v-52a6 6 0 0 0-6-6h-26V256z" />
					</svg>
				</button>
			</li>
		</ul>
    </li>
    <li style="margin-left: auto;">
        <ul class="action-group">
			<li>
				<select id="snapToGrid" title="{{{LANG_SNAP_TO_GRID}}}">
					<option value="0">{{{LANG_NO_GRID}}}</option>
					<option value="5">5 px</option>
					<option value="10">10 px</option>
					<option value="20">20 px</option>
					<option value="50">50 px</option>
				</select>
			</li>
           <li>
                <label>
                    <input type="number" id="imageWidth" value="1920" step="1" min="0" style="width:80px;" title="{{{LANG_RESOLUTION}}}"> x
                    <input type="number" id="imageHeight" value="1080" step="1" min="0" style="width:80px;" title="{{{LANG_RESOLUTION}}}">
                </label>
            </li>
            <li style="display: flex; justify-content: center; gap:5px; align-items:center;">
                <input style="width:120px;" type="range" min="20" max="500" value="100" step="5" id="zoomSlider" title="{{{LANG_ZOOM}}}">
                <span id="zoomPercent"></span>
            </li>
			{{#save_formats}}
			<li>
				<select id="exportFormat" title="{{{LANG_FORMATS}}}">
					{{#formats}}
						<option value="{{{FORMAT}}}">{{{LANG_FORMAT}}}</option>
					{{/formats}}
				</select>
            </li>
			<li>
				<input type="number" id="exportQuality" min="10" max="100" step="1" value="80" title="{{{LANG_IMAGE_QUALITY}}}"> %
            </li>
			{{/save_formats}}
			<li>
                <button id="save" title="{{{LANG_SAVE}}}"><i class="bi bi-floppy"></i></button>
            </li>
			{{#reset}}
			<li>
				<button id="reset" title="{{{LANG_RESET}}}"><i class="bi bi-arrow-repeat"></i></button>
            </li>
			{{/reset}}
            <li>
                <button id="close" title="{{{LANG_CLOSE}}}"><i class="bi bi-box-arrow-in-right"></i></button>
            </li>
        </ul>
    </li>
</ul>

<div id="canvasWrap" tabIndex="1000" style="width:100%;height:93%;padding:0.5%;overflow:hidden;">
	<input type="hidden" id="template_id" value="{{{TEMPLATE_ID}}}">
	{{#is_playlist_item}}
	<input type="hidden" id="item_id" value="{{{ITEM_ID}}}">
	<input type="hidden" id="playlist_id" value="{{{PLAYLIST_ID}}}">
	{{/is_playlist_item}}
    <canvas id="canvas" style="box-shadow: 0 2px 6px 0 #666, 0 2px 6px 0 #666;"></canvas>
</div>
<script>
    let lang = {
		"confirm_close": "{{{LANG_CONFIRM_CLOSE_EDITOR}}}",
		"confirm_reset": "{{{LANG_CONFIRM_RESET}}}",
		"add_image": "{{{LANG_INSERT_IMAGE}}}",
		"replace_image": "{{{LANG_REPLACE_IMAGE}}}"
	};
</script>

