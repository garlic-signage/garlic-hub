										d="M2446.9,1109V716.2h2155.5H6758V323.4V-69.4h392.8h392.8v785.6v785.6H4995.2H2446.9V1109z" />
								<path
										d="M2446.9,122.2V-69.4h1762.7h1762.8V-376v-306.6h201.2h201.2v498.2v498.2H4410.8H2446.9V122.2z" />
								<path
										d="M6710.1-893.3l-132.2-134.1l99.6-101.5c55.6-55.6,99.6-107.3,99.6-115s-90.1-13.4-201.2-13.4h-201.2V-1449v-191.6h214.6H6804l-113-115l-115-115l139.9-139.9l138-138l348.7,350.6l350.6,348.7l-344.9,344.9c-189.7,189.7-348.7,344.9-354.5,344.9C6848-759.2,6782.9-818.6,6710.1-893.3z" />
