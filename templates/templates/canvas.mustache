<h1>{{{LANG_PAGE_HEADER}}}</h1>

	<ul id="composerContextMenu"  class="context-menu">
		<li id="replaceImage" class="bi-image"> {{{LANG_REPLACE_IMAGE}}}</li>
		<li id="duplicate" class="bi-copy">{{{LANG_DUBLICATE}}}</li>
		<li id="delete" class="bi-trash">{{{LANG_DELETE}}}</li>
		{{#is_selectable}}
		<li>
			<hr />
		</li>
			<li id="toggleLock"><span id="lock" class="bi-lock"> {{{LANG_LOCK}}}</span><span id="unlock" class="bi-unlock"> {{{LANG_UNLOCK}}}</span></li>
		<!--	<li id="toggleSelectable"><span id="unselectable" class="bi-hand-index"> {{{LANG_UNSELECTABLE}}}</span><span id="selectable" class="bi-hand-thumbs-down"> {{{LANG_SEELCTABLE}}}</span></li>
-->
{{/is_selectable}}
		<li>
			<hr />
		</li>
		<li id="moveBackground" class="bi-back">{{{LANG_MOVE_BACKGROUND}}}</li>
		<li id="moveBack" class="bi-arrow-down">{{{LANG_MOVE_BACK}}}</li>
		<li id="moveFront" class="bi-arrow-up">{{{LANG_MOVE_FRONT}}}</li>
		<li id="moveForeground" class="bi-front">{{{LANG_MOVE_FOREGROUND}}}</li>
	</ul>

{{> media_selector}}
<dialog id="mediaSelectorDialog">
	<header>
		<span class="dialog-name"></span>
		<button id="closeEditMediaDialog" class="close-button bi bi-x" aria-label="Close"></button>
	</header>
	<section id="mediaSelectorInstance"></section>
	<footer>
		<button id="addMedia" type="button">{{{LANG_ADD_MEDIA}}}</button>
		<button id="applyMedia" type="button">{{{LANG_APPLY_MEDIA}}}</button>
		<button id="closeDialogButton" type="button">{{{LANG_CANCEL}}}</button>
	</footer>
</dialog>

<ul id="canvas_toolbar">
    <li id="inserts">
        <ul class="action-group" data-label="{{{LANG_INSERT}}}">
            <li>
                <button id="insertImage" class="bi bi-image" title="{{{LANG_INSERT_IMAGE}}}"></button>
            </li>
            <li>
                <button id="insertText" title="{{{LANG_INSERT_TEXT}}}">Aa</button>
            </li>
            <li class="template_edit_dropdown">
                <button class="svg_button" title="{{{LANG_INSERT_SHAPE}}}" >
                    <svg xmlns="http://www.w3.org/2000/svg" width="17px" height="17px" viewBox="0 0 512 512">
                        <path style="fill:none;stroke:#000;stroke-linejoin:round;stroke-width:32px;" d="M336 320L32 320L184 48L336 320z" />
                        <path d="M265.32,194.51A144,144,0,1,1,192,320" style="fill:none;stroke:#000;stroke-linejoin:round;stroke-width:32px;" />
                    </svg>
                </button>
                <div class="template_edit_dropdown_content" style="padding:20px;">
                    <div style=" display: flex; justify-content:space-between; align-items: center; gap:20px;">
                        <button id="insertCircle" class="bi bi-circle-fill" title="{{{LANG_INSERT_CIRCLE}}}"></button>
                        <button id="insertTriangle" class="bi bi-triangle-fill" title="{{{LANG_INSERT_TRIANGLE}}}"></button>
                        <button id="insertRectangle" class="bi bi-square-fill" title="{{{LANG_INSERT_RECTANGLE}}}"></button>
                    </div>
                    <div style=" display: flex; justify-content:space-between; align-items: center; gap:20px; margin-top:20px;">
                        <button id="insertPolygon"  class="bi bi-pentagon-fill" title="{{{LANG_INSERT_PENTAGONE}}}"></button>
                        <button id="insertHexagon" class="bi bi-hexagon-fill" title="{{{LANG_INSERT_HEXAGON}}}">
                        </button>
                        <button id="insertOctagon" class="bi bi-octagon-fill" title="{{{LANG_INSERT_OCTAGON}}}"></button>
                    </div>
                </div>
            </li>
        </ul>
    </li>
    <li id="undo_redo">
        <ul class="action-group" data-label="{{{LANG_HISTORY}}}">
            <li>
                <button id="undo" class="bi bi-arrow-counterclockwise" title="{{{LANG_UNDO}}}"></button>
            </li>
            <li>
                <button id="redo" class="bi bi-arrow-clockwise"  title="{{{LANG_REDO}}}"></button>
            </li>
        </ul>
    </li>
    <li id="properties">
		<ul id="globalProperties" class="action-group" style="display:none;">
			<li class="template_edit_dropdown">
				<button id="object_opacity_btn" class="bi bi-transparency" title="{{{LANG_OPACITY}}}"></button>
				<div class="template_edit_dropdown_content" style="width:240px;padding:20px;">
					<label for="opacity">
						{{{LANG_OPACITY}}}
					</label>
					<div style="display: flex; justify-content:space-between; align-items: center;">
						<input id="opacity" style="width:150px;" type="range" min="0" max="100" value="100">
						<span id="opacityDisplay">100</span>%
					</div>
				</div>
			</li>
			<li class="template_edit_dropdown">
				<button id="object_shadow" class="bi bi-shadows" title="{{{LANG_SHADOW}}}"></button>
				<div class="template_edit_dropdown_content" style="padding:20px;">
					<div style=" display: flex; justify-content:space-between; align-items: center;">
						<div style="display:flex; flex-direction:column;">
							<label for="shadowColor">{{{LANG_SHADOW_COLOR}}}</label>
							<input id="shadowColor" style="width:50px; text-align:center;" type="color" value="#ccccc">
						</div>
						<div style="display:flex; flex-direction:column; padding:20px;">
							<label for="shadowOffsetX">{{{LANG_SHADOW_OFFSET_X}}}</label>
							<input id="shadowOffsetX" style="width:70px; text-align:center;" type="number" value="0">
						</div>
						<div style="display:flex; flex-direction:column; padding:20px;">
							<label for="shadowOffsetY">{{{LANG_SHADOW_OFFSET_Y}}}</label>
							<input id="shadowOffsetY" style="width:70px; text-align:center;" type="number" value="0">
						</div>
						<div style="display:flex; flex-direction:column; padding:20px;">
							<label for="shadowBlur">{{{LANG_SHADOW_BLUR}}}</label>
							<input id="shadowBlur" style="width:70px; text-align:center;" type="number" value="0">
						</div>
						<div style="display:flex; flex-direction:column; align-items: flex-end; padding:20px;">
							<button id="createShadow" class="bi bi-plus-circle-dotted" style="height:35px;width:35px;margin-top:20px;" title="{{{LANG_SHADOW_CREATE}}}"></button>
							<button id="deleteShadow" class="bi bi-trash" style="height:35px;width:35px;margin-top:20px;" title="{{{LANG_SHADOW_DELETE}}}"></button>
						</div>
					</div>
				</div>
			</li>
			<li class="template_edit_dropdown">
				<button id="object_align" class="bi bi-align-middle" title="{{{LANG_ALIGN_OBJECT}}}"></button>
				<div class="template_edit_dropdown_content" style="width:180px; padding:0 20px 20px 20px;">
					<p>{{{LANG_ALIGN_OBJECT}}}</p>
					<div style=" display: flex; justify-content:space-between; align-items: center; gap:20px;">
						<button id="alignLeft" class="bi bi-align-start" title="{{{LANG_ALIGN_LEFT}}}"></button>
						<button id="alignCenter" class="bi bi-align-center" title="{{{LANG_ALIGN_CENTER}}}"></button>
						<button id="alignRight" class="bi bi-align-end"	title="{{{LANG_ALIGN_RIGHT}}}"></button>
					</div>
					<div style=" display: flex; justify-content:space-between; align-items: center; gap:20px; margin-top:20px;">
						<button id="alignTop" class="bi bi-align-top" title="{{{LANG_ALIGN_TOP}}}"></button>
						<button id="alignMiddle" class="bi bi-align-middle" title="{{{LANG_ALIGN_MIDDLE}}}"></button>
						<button id="alignBottom" class="bi bi-align-bottom"  title="{{{LANG_ALIGN_BOTTOM}}}"></button>
					</div>
				</div>
			</li>
			<li class="action-group" data-label="{{{LANG_OUTLINE}}}">
				<input type="color" id="strokeColor" class="color_button" title="{{{LANG_OUTLINE_COLOR}}}" />
				<div class="template_edit_dropdown">
					<button id="object_outline" class="svg_button" title="{{{LANG_OUTLINE_STRENGTH}}}">
						<svg xmlns="http://www.w3.org/2000/svg" width="17px" height="17px" viewBox="0 0 500 500" xml:space="preserve">
